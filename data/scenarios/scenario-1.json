      "text": "Meho izlazi iz sobe."
    },
    {
      "lineId": 5,
      "nextLineId": 6,
      "text": "EMIN"
    },
    {
      "lineId": 6,
      "nextLineId": 7,
      "text": "Ja mnogo volim kafu. Pridjevi za kafu su jaka, gorka, blaga, slatka, kisela, gusta, kremasta, crna, bistra, pjenasta, mirisna, aromaticna,"
    },
    {
      "lineId": 7,
      "nextLineId": 8,
      "text": "MEHO"
    },
    {
      "lineId": 8,
      "nextLineId": 9,
      "text": "Bas je tmuran dan! Kako cu danas na planinu? Nikako! Eto kako. Mrzim ovaj smog. I ove oblake."
    },
    {
      "lineId": 9,
      "nextLineId": 10,
      "text": "MEHO"
    },
    {
      "lineId": 10,
      "nextLineId": null,
      "text": "turska, domaca, kratka, produzena mmmm"
    }
